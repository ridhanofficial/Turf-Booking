# ─────────────────────────────────────────────────────────────────────────────
# Viswa Sports — Environment Variables
# Copy this file to .env and fill in all values before starting the server.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string. Replace password with your chosen value.
POSTGRES_PASSWORD=your_strong_postgres_password_here
DATABASE_URL=postgresql+asyncpg://postgres:your_strong_postgres_password_here@postgres:5432/viswa_sports

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── JWT Secrets ──────────────────────────────────────────────────────────────
# Generate strong secrets with: openssl rand -hex 32
JWT_SECRET_KEY=REPLACE_WITH_OPENSSL_RAND_HEX_32_OUTPUT
ADMIN_JWT_SECRET_KEY=REPLACE_WITH_DIFFERENT_OPENSSL_RAND_HEX_32_OUTPUT

# ── Razorpay ─────────────────────────────────────────────────────────────────
# Get keys from: https://dashboard.razorpay.com/app/keys
# Use rzp_test_* keys for testing, rzp_live_* for production
RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ── Twilio (OTP + SMS) ───────────────────────────────────────────────────────
# Get from: https://console.twilio.com
OTP_MOCK_MODE=false
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# Option A — Twilio Verify (recommended, handles OTP internally)
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Option B — Twilio Messaging API (only if not using Verify)
# TWILIO_FROM_NUMBER=+1234567890

# Required for booking confirmation/cancellation SMS (always needed)
TWILIO_FROM_NUMBER=+1234567890

# ── Admin Credentials ────────────────────────────────────────────────────────
# The admin account is auto-seeded on first startup with these values.
# Change them BEFORE the first `docker-compose up`.
ADMIN_EMAIL=admin@yourcompany.com
ADMIN_PASSWORD=change_me_to_a_very_strong_password

# ── App Settings ─────────────────────────────────────────────────────────────
APP_ENV=production

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# How many minutes a slot is held while user completes payment (default: 5)
SLOT_HOLD_MINUTES=5

# ── Frontend (passed to Next.js) ─────────────────────────────────────────────
# The URL your frontend can reach the backend at (public-facing)
NEXT_PUBLIC_API_URL=https://yourdomain.com
