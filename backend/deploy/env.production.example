# ─── Viswa Sports — Production Environment (.env.prod) ───────────────────────
# COPY this file to the project root as .env.prod on EC2, then fill every value.
# Run: cp backend/deploy/env.production.example .env.prod
#
# Permissions:  chmod 600 .env.prod
# NEVER commit .env.prod to git.

# ── PostgreSQL (self-hosted on EC2 via Docker Compose) ───────────────────────
POSTGRES_DB=viswa_sports
POSTGRES_USER=viswa_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD   # min 20 chars, no @ or special chars

# ── Redis (self-hosted on EC2 via Docker Compose) ────────────────────────────
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD   # min 20 chars

# NOTE: DATABASE_URL and REDIS_URL are auto-set in docker-compose.prod.yml
# using internal service names (postgres:5432, redis:6379). Do NOT set them here.

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=production
APP_NAME=Viswa Sports

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate: python3 -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET_KEY=CHANGE_ME_MIN_64_CHARS
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Generate a DIFFERENT key for admin:
ADMIN_JWT_SECRET_KEY=CHANGE_ME_MIN_64_CHARS_DIFFERENT_FROM_ABOVE

# ── Admin Seed ────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD

# ── Razorpay ──────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_CHANGE_ME
RAZORPAY_KEY_SECRET=CHANGE_ME

# ── Twilio OTP ────────────────────────────────────────────────────────────────
OTP_MOCK_MODE=false
TWILIO_ACCOUNT_SID=AC_CHANGE_ME
TWILIO_AUTH_TOKEN=CHANGE_ME
TWILIO_VERIFY_SERVICE_SID=VA_CHANGE_ME

# ── Gmail SMTP ────────────────────────────────────────────────────────────────
# App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=yourmail@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
SMTP_FROM_NAME=Viswa Sports Arena

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=CHANGE_ME.apps.googleusercontent.com

# ── CORS ──────────────────────────────────────────────────────────────────────
# Your frontend domain(s). Comma-separated. No trailing slash.
CORS_ORIGINS=https://viswasports.com

# ── Misc ──────────────────────────────────────────────────────────────────────
SLOT_HOLD_MINUTES=5
WEB_CONCURRENCY=2    # 2 for t3.micro; increase on larger instances
